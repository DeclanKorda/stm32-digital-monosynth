/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */
void DMA_Callback(void){
	buffer_half = (buffer_half+1)%2; // switch to the other half of the buffer.
	float local_phase = phase;
	float local_phase_increment = phase_increment;

	uint32_t *local_buffer = buffer + BUFFER_LENGTH*buffer_half;

	if (phase_increment == 0){
		for(uint16_t i = 0; i < BUFFER_LENGTH; i++){
			local_buffer[i] = 2048;
		}
	}
	else{
		int32_t sample;
		int32_t phase_int;
		switch(waveform){
		case 0:
			// sin wave generator
			for(uint16_t i = 0; i < BUFFER_LENGTH; i++){
				phase_int = (int32_t)local_phase;
				sample = 2048 + sineLookupTable[phase_int];
				if (sample > 4095) sample = 4095;
				else if (sample < 0) sample = 0;
				local_buffer[i] = sample;
				local_phase = local_phase + local_phase_increment;
				if (local_phase >= TABLE_LENGTH)
					local_phase = local_phase - TABLE_LENGTH;
			}
			break;
		case 1:
			// saw wave generator

			for(uint16_t i = 0; i < BUFFER_LENGTH; i++){
				sample = ((uint32_t)(2048 + 4*local_phase))%4095; // (2048 + 4x)%4096
				if (sample > 4095) sample = 4095;
				else if (sample < 0) sample = 0;
				local_buffer[i] = sample;
				local_phase = local_phase + local_phase_increment;
				if (local_phase >= TABLE_LENGTH)
					local_phase = local_phase - TABLE_LENGTH;
			}
			break;
		case 2:
			//square wave generator

			for(uint16_t i = 0; i < BUFFER_LENGTH; i++){
				if (local_phase < TABLE_LENGTH/2)
					local_buffer[i] = 0;
				else
					local_buffer[i] = 4095;
				local_phase = local_phase + local_phase_increment;
				if (local_phase >= TABLE_LENGTH)
					local_phase = local_phase - TABLE_LENGTH;
			}
			break;

		}


	}
	phase = local_phase;


}

void MIDI_Callback(void){

    switch (midi_state){
		case 0:
			if ((midi_rx & 0x80) == 0){
				// this is a data byte.
				midi_data1 = midi_rx;
				midi_state = 2;
			}
			else {
				midi_status = midi_rx;
				midi_state = 1;
			}
			break;

		case 1:
			// first data byte
			midi_data1 = midi_rx;
			midi_state = 2;
			break;

		case 2:
			// second data byte. Now we process the entire message.
			midi_data2 = midi_rx;
		    switch (midi_status & 0xF0) {
		        case 0x80:  // Note Off
		            note_pressed[midi_data1] = 0;
		            break;

		        case 0x90:  // Note On

		            note_pressed[midi_data1] = 1;

		            break;

		        default:
		            // Ignore other messages (CC, Pitch Bend, etc.)
		            break;
		    }
		    float local_phase_increment = 0;
			for(uint16_t i = 0; i < 128; i++){
					if (note_pressed[127-i] == 1){
						local_phase_increment = (midiNoteFreq[127-i] * (float)TABLE_LENGTH)/ (float)SAMPLE_RATE;
						break;
					}
				}
			// update phase increment
			phase_increment = local_phase_increment;
			midi_state = 0;
		    break;

    }



	HAL_UART_Receive_IT(&huart1, &midi_rx, 1);

}




/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* MPU Configuration--------------------------------------------------------*/
  MPU_Config();

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_GPDMA1_Init();
  MX_ADC1_Init();
  MX_TIM1_Init();
  MX_ICACHE_Init();
  MX_DAC1_Init();
  MX_USART1_UART_Init();
  /* USER CODE BEGIN 2 */
  for (int16_t i = 0; i < BUFFER_LENGTH*2; i++){
		  buffer[i] = 2048;
  }
  //start DMA
  HAL_DAC_Start_DMA(&hdac1, DAC_CHANNEL_2, (uint32_t*)buffer, BUFFER_LENGTH*2, DAC_ALIGN_12B_R);
  HAL_TIM_Base_Start(&htim1);

  HAL_UART_Receive_IT(&huart1, &midi_rx, 1);


  uint32_t DebounceDelay = 20;    // The Ddebounce Time; increase it if the output still flickers

  uint32_t LastDebounceTime_A = 0;  // The Last Time The Output Pin Was Toggled
  uint8_t BtnState_A = 0;               // The Current Reading From The Input Pin
  uint8_t LastBtnState_A = 0;       // The previous reading from The Input Pin
  uint8_t TempBtnReading_A;

  uint32_t LastDebounceTime_D = 0;  // The Last Time The Output Pin Was Toggled
  uint8_t BtnState_D = 0;               // The Current Reading From The Input Pin
  uint8_t LastBtnState_D = 0;       // The previous reading from The Input Pin
  uint8_t TempBtnReading_D;

  uint32_t LastDebounceTime_S = 0;  // The Last Time The Output Pin Was Toggled
  uint8_t BtnState_S = 0;               // The Current Reading From The Input Pin
  uint8_t LastBtnState_S = 0;       // The previous reading from The Input Pin
  uint8_t TempBtnReading_S;
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
	  // ATTACK / SINE WAVE BUTTON
	  TempBtnReading_A = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_10); // read the state of the switch into a local variable:
	      if(TempBtnReading_A != LastBtnState_A) // If the switch changed, due to noise or pressing:
	      {
	          LastDebounceTime_A = HAL_GetTick(); // reset the debouncing timer
	      }
	      if((HAL_GetTick() - LastDebounceTime_A) > DebounceDelay)
	      {
	          if(TempBtnReading_A != BtnState_A)
	          {
	              BtnState_A = TempBtnReading_A;
	              if(BtnState_A == 1)
	              {
	                  waveform = 0;
	              }
	          }
	      }
	      LastBtnState_A = TempBtnReading_A;
	  // DECAY / SAW WAVE BUTTON
	  TempBtnReading_D = HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_3); // read the state of the switch into a local variable:
			  if(TempBtnReading_D != LastBtnState_D) // If the switch changed, due to noise or pressing:
			  {
				  LastDebounceTime_D = HAL_GetTick(); // reset the debouncing timer
			  }
			  if((HAL_GetTick() - LastDebounceTime_D) > DebounceDelay)
			  {
				  if(TempBtnReading_D != BtnState_D)
				  {
					  BtnState_D = TempBtnReading_D;
					  if(BtnState_D == 1)
					  {
						  waveform = 1;
					  }
				  }
			  }
			  LastBtnState_D = TempBtnReading_D;
	  // SUSTAIN / SQUAREWAVE BUTTON
	  TempBtnReading_S = HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_5); // read the state of the switch into a local variable:
			  if(TempBtnReading_S != LastBtnState_S) // If the switch changed, due to noise or pressing:
			  {
				  LastDebounceTime_S = HAL_GetTick(); // reset the debouncing timer
			  }
			  if((HAL_GetTick() - LastDebounceTime_S) > DebounceDelay)
			  {
				  if(TempBtnReading_S != BtnState_S)
				  {
					  BtnState_S = TempBtnReading_S;
					  if(BtnState_S == 1)
					  {
						  waveform = 2;
					  }
				  }
			  }
			  LastBtnState_S = TempBtnReading_S;

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

/**
  * @brief System Clock Configuration
  * @retval None
  */
void SystemClock_Config(void)
{
  RCC_OscInitTypeDef RCC_OscInitStruct = {0};
  RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

  /** Configure the main internal regulator output voltage
  */
  __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE0);

  while(!__HAL_PWR_GET_FLAG(PWR_FLAG_VOSRDY)) {}

  /** Initializes the RCC Oscillators according to the specified parameters
  * in the RCC_OscInitTypeDef structure.
  */
  RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_LSI|RCC_OSCILLATORTYPE_HSE;
  RCC_OscInitStruct.HSEState = RCC_HSE_ON;
  RCC_OscInitStruct.LSIState = RCC_LSI_ON;
  RCC_OscInitStruct.PLL.PLLState = RCC_PLL_ON;
  RCC_OscInitStruct.PLL.PLLSource = RCC_PLL1_SOURCE_HSE;
  RCC_OscInitStruct.PLL.PLLM = 12;
  RCC_OscInitStruct.PLL.PLLN = 250;
  RCC_OscInitStruct.PLL.PLLP = 2;
  RCC_OscInitStruct.PLL.PLLQ = 2;
  RCC_OscInitStruct.PLL.PLLR = 2;
  RCC_OscInitStruct.PLL.PLLRGE = RCC_PLL1_VCIRANGE_1;
  RCC_OscInitStruct.PLL.PLLVCOSEL = RCC_PLL1_VCORANGE_WIDE;
  RCC_OscInitStruct.PLL.PLLFRACN = 0;
  if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK)
  {
    Error_Handler();
  }

  /** Initializes the CPU, AHB and APB buses clocks
  */
  RCC_ClkInitStruct.ClockType = RCC_CLOCKTYPE_HCLK|RCC_CLOCKTYPE_SYSCLK
                              |RCC_CLOCKTYPE_PCLK1|RCC_CLOCKTYPE_PCLK2
                              |RCC_CLOCKTYPE_PCLK3;
  RCC_ClkInitStruct.SYSCLKSource = RCC_SYSCLKSOURCE_PLLCLK;
  RCC_ClkInitStruct.AHBCLKDivider = RCC_SYSCLK_DIV1;
  RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV1;
  RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;
  RCC_ClkInitStruct.APB3CLKDivider = RCC_HCLK_DIV1;

